---
// Scroll effects: horizontal slide-in parallax on imagery (desktop) + a
// typewriter reveal on the section headers, typed one at a time in the order
// they enter the viewport. Respects prefers-reduced-motion.
---

<script>
  import gsap from 'gsap';
  import ScrollTrigger from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const CHAR_MS = 42; // base per-character delay (tagline, contact line); jittered below
  const HEADER_MS = 72; // slower per-character delay for the landing header

  /* ---- Typewriter reveal ----------------------------------------------- */
  function wrapChars(el: HTMLElement) {
    const walk = (node: Node) => {
      Array.from(node.childNodes).forEach((child) => {
        if (child.nodeType === Node.TEXT_NODE) {
          const frag = document.createDocumentFragment();
          for (const ch of child.textContent ?? '') {
            const span = document.createElement('span');
            span.className = 'type-char is-pending';
            span.textContent = ch;
            frag.appendChild(span);
          }
          node.replaceChild(frag, child);
        } else if (child.nodeType === Node.ELEMENT_NODE && (child as HTMLElement).tagName !== 'BR') {
          walk(child);
        }
      });
    };
    walk(el);
    const chars = Array.from(el.querySelectorAll<HTMLElement>('.type-char'));
    // Drop leading/trailing whitespace spans (template indentation) so typing
    // starts on the first real character; internal spaces are kept.
    while (chars.length && !chars[0].textContent?.trim()) chars.shift()!.remove();
    while (chars.length && !chars[chars.length - 1].textContent?.trim()) chars.pop()!.remove();

    const caret = document.createElement('span');
    caret.className = 'type-caret is-pending';
    caret.setAttribute('aria-hidden', 'true');
    caret.textContent = '|';
    el.appendChild(caret);
    return { chars, caret };
  }

  function typeOne(item: { chars: HTMLElement[]; caret: HTMLElement; charMs?: number }): Promise<void> {
    return new Promise((resolve) => {
      const { chars, caret } = item;
      const charMs = item.charMs ?? CHAR_MS;
      // Start the caret at the head of the text, then move it to follow each
      // typed character so it stays on the correct line (e.g. across the <br>).
      chars[0].before(caret);
      caret.classList.remove('is-pending');
      let i = 0;
      const tick = () => {
        if (i >= chars.length) {
          caret.classList.add('is-done');
          resolve();
          return;
        }
        chars[i].classList.remove('is-pending');
        chars[i].after(caret);
        i += 1;
        window.setTimeout(tick, charMs);
      };
      tick();
    });
  }

  // Landing header, typed with a deliberate human slip: types
  // "SOSAIAH / HILLIER-BRNES", backspaces to "HILLIER-B", then finishes
  // "HILLIER-BARNES*". Builds its own char spans (with a following caret) and
  // drives them on a human-jittered clock.
  function typeHeader(el: HTMLElement, charMs: number): Promise<void> {
    return new Promise((resolve) => {
      el.textContent = '';
      const line1 = document.createElement('span');
      const line2 = document.createElement('span');
      const br = document.createElement('br');
      const caret = document.createElement('span');
      caret.className = 'type-caret';
      caret.setAttribute('aria-hidden', 'true');
      caret.textContent = '|';
      el.append(line1, br, line2, caret);

      const put = (line: HTMLElement, ch: string) => {
        const s = document.createElement('span');
        s.className = 'type-char';
        s.textContent = ch;
        line.appendChild(s);
        line.after(caret); // caret follows the line being typed
      };
      const del = (line: HTMLElement) => {
        line.lastElementChild?.remove();
        line.after(caret);
      };

      type Step = { fn: () => void; kind: 'type' | 'back' | 'wait'; ms?: number };
      const steps: Step[] = [];
      for (const ch of 'SOSAIAH') steps.push({ fn: () => put(line1, ch), kind: 'type' });
      for (const ch of 'HILLIER-BRNES') steps.push({ fn: () => put(line2, ch), kind: 'type' });
      steps.push({ fn: () => {}, kind: 'wait', ms: charMs * 7 }); // notice the typo
      for (let k = 0; k < 4; k++) steps.push({ fn: () => del(line2), kind: 'back' }); // RNES -> B
      steps.push({ fn: () => {}, kind: 'wait', ms: charMs * 3 }); // settle before retyping
      for (const ch of 'ARNES*') steps.push({ fn: () => put(line2, ch), kind: 'type' });

      let i = 0;
      const tick = () => {
        if (i >= steps.length) {
          caret.classList.add('is-done');
          resolve();
          return;
        }
        const step = steps[i++];
        step.fn();
        const d = step.kind === 'wait' ? step.ms! : step.kind === 'back' ? charMs * 0.55 : charMs;
        window.setTimeout(tick, d);
      };
      tick();
    });
  }

  function setupTyping() {
    // Global FIFO queue so only one thing types at a time.
    type Item = { chars?: HTMLElement[]; caret?: HTMLElement; delay?: number; charMs?: number; run?: () => Promise<void> };
    const queue: Item[] = [];
    let working = false;
    async function pump() {
      if (working) return;
      working = true;
      while (queue.length) {
        const item = queue.shift()!;
        if (item.delay) await new Promise((r) => window.setTimeout(r, item.delay));
        if (item.run) await item.run();
        else await typeOne(item as { chars: HTMLElement[]; caret: HTMLElement; charMs?: number });
      }
      working = false;
    }

    const prep = (el: HTMLElement | null) => {
      if (!el) return null;
      el.style.minHeight = el.offsetHeight + 'px'; // reserve height (no collapse)
      const item = wrapChars(el);
      return item.chars.length ? item : null;
    };

    // Landing: type the hero name, then the "Really cool and nice" tagline right
    // after it finishes. Triggered by the intro (first visit) or immediately
    // (revisit) — see setupIntro / init.
    const nameEl = document.querySelector<HTMLElement>('.name');
    if (nameEl) {
      nameEl.style.minHeight = nameEl.offsetHeight + 'px'; // reserve height (no collapse)
      nameEl.textContent = ''; // hide the static header now so it never flashes before typing
    }
    const taglineItem = prep(document.querySelector<HTMLElement>('.tagline'));
    let landingStarted = false;
    const startLanding = () => {
      if (landingStarted || !nameEl) return;
      landingStarted = true;
      queue.push({ run: () => typeHeader(nameEl, HEADER_MS) });
      if (taglineItem) queue.push({ ...taglineItem, delay: 900 });
      pump();
    };

    // "Let's build something" on the contact page types out once the user has
    // scrolled all the way to the bottom of the page (scrolling complete).
    const build = document.querySelector<HTMLElement>('.build');
    if (build) {
      build.style.minHeight = build.offsetHeight + 'px';
      const item = wrapChars(build);
      if (item.chars.length) {
        // Type as soon as the line scrolls into view (minimal delay). A scroll
        // check on the element's own rect is reliable here — a ScrollTrigger
        // mis-measures absolutely-positioned elements inside the scaled canvas.
        let fired = false;
        const check = () => {
          if (fired) return;
          if (build.getBoundingClientRect().top < window.innerHeight * 0.92) {
            fired = true;
            window.removeEventListener('scroll', check);
            queue.push(item);
            pump();
          }
        };
        window.addEventListener('scroll', check, { passive: true });
        check();
      }
    }

    return startLanding;
  }

  /* ---- Landing intro: masked clip reveals, then start typing ------------ */
  function setupIntro(startLanding: () => void) {
    const root = document.documentElement;
    if (!root.classList.contains('intro')) {
      // Revisit / no intro — just type.
      startLanding();
      return;
    }

    const curtain = document.getElementById('curtain');
    const countEl = document.getElementById('curtain-count');
    const brand = curtain?.querySelector('.curtain__brand');
    const panelTop = curtain?.querySelector('.curtain__panel--top');
    const panelBottom = curtain?.querySelector('.curtain__panel--bottom');
    if (!curtain || !panelTop || !panelBottom) {
      root.classList.remove('intro');
      startLanding();
      return;
    }

    // Landing content settles in as the curtain reveals it (hero images are
    // skipped — the parallax owns their opacity/transform).
    const q = (sel: string) => Array.from(document.querySelectorAll<HTMLElement>('#top ' + sel));
    const settleEls = [...q('.lnav'), ...q('.blurb'), ...q('.scroll-hint'), ...q('.page-num')];
    gsap.set(settleEls, { opacity: 0, y: 26 });

    const markPlayed = () => {
      try { sessionStorage.setItem('introPlayed', '1'); } catch (e) {}
    };

    const count = { v: 0 };
    const tl = gsap.timeline({
      onComplete: () => { root.classList.remove('intro'); markPlayed(); },
    });
    // 0 → 100 loader counter
    tl.to(count, {
      v: 100,
      duration: 1.1,
      ease: 'power1.inOut',
      onUpdate: () => {
        if (countEl) countEl.textContent = String(Math.round(count.v)).padStart(3, '0');
      },
    }, 0);
    // brand fades, then panels split apart to reveal the page
    tl.to(brand, { opacity: 0, duration: 0.35, ease: 'power2.in' }, 1.15);
    tl.to(panelTop, { yPercent: -100, duration: 1.0, ease: 'power4.inOut' }, 1.35);
    tl.to(panelBottom, { yPercent: 100, duration: 1.0, ease: 'power4.inOut' }, 1.35);
    // content settles in as the gap opens
    tl.to(settleEls, { opacity: 1, y: 0, duration: 0.8, stagger: 0.08, ease: 'power3.out' }, 1.6);
    // name types as the curtain finishes lifting
    tl.call(startLanding, [], 2.0);

    // Safety: if something stalls, still reveal + type.
    window.setTimeout(() => {
      root.classList.remove('intro');
      gsap.set(settleEls, { opacity: 1, y: 0 });
      markPlayed();
      startLanding();
    }, 6000);
  }

  /* ---- Horizontal slide-in parallax (desktop only) --------------------- */
  function setupParallax() {
    const mm = gsap.matchMedia();
    mm.add('(min-width: 1024px)', () => {
      gsap.utils.toArray<HTMLElement>('.frame').forEach((section) => {
        // Images, section headers, and the Credentials Cloud media block (image +
        // play overlay, animated as one unit) slide in horizontally from their side.
        section
          .querySelectorAll<HTMLElement>('.canvas img:not(.cc-media-img), .heading, .cc-media')
          .forEach((el) => {
            const rect = el.getBoundingClientRect();
            // Direction defaults to the element's side; `data-parallax` can override.
            const dir = el.dataset.parallax;
            const fromLeft =
              dir === 'left' ? true : dir === 'right' ? false : rect.left + rect.width / 2 < window.innerWidth / 2;

            const fromX = fromLeft ? -85 : 85;

            // Settle at the element's own CSS opacity (images are 0.8 by default,
            // text 1; .work-img / .cc-media override to 1).
            const targetAlpha = parseFloat(getComputedStyle(el).opacity) || 1;

          gsap.fromTo(
            el,
            { xPercent: fromX, autoAlpha: 0 },
            {
              xPercent: 0,
              autoAlpha: targetAlpha,
              ease: 'none',
              scrollTrigger: {
                trigger: section,
                start: 'top bottom',
                end: 'center 65%',
                scrub: true,
              },
            }
          );
        });
      });
    });
  }

  function init() {
    if (reduceMotion) return;
    const startLanding = setupTyping();
    setupIntro(startLanding);
    setupParallax();
    window.addEventListener('load', () => ScrollTrigger.refresh());
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
